# Google Cloud
GOOGLE_CLOUD_PROJECT=rising-reserve-352718
BQ_LOCATION=US

# Datasets do BigQuery
BQ_DATASET_BRONZE=tc_alfabetizacao_bronze
BQ_DATASET_SILVER=tc_alfabetizacao_silver
BQ_DATASET_GOLD=tc_alfabetizacao_gold
BQ_DATASET_AUDIT=tc_alfabetizacao_audit

# Ambiente
APP_ENV=development
LOG_LEVEL=INFO

# Streaming local
KAFKA_BOOTSTRAP_SERVERS=localhost:19092
KAFKA_TOPIC=alfabetizacao-events
KAFKA_CONSUMER_GROUP=alfabetizacao-consumer

# Processamento
STREAMING_BATCH_SIZE=20
STREAMING_BATCH_INTERVAL_SECONDS=10